# Copy this file to .env and fill in your Fyers credentials.
# The pre-market report reads live data from Fyers when these are set;
# without them it falls back to Yahoo Finance / NSE public data.
#
# Create an app at https://myapi.fyers.in/dashboard to get the App ID / Secret.

# --- Fyers API (live market data) ---
FYERS_APP_ID=your_app_id_here          # e.g. LQFQ2OU7AQ-100
FYERS_SECRET_KEY=your_secret_key_here
FYERS_REDIRECT_URI=https://trade.fyers.in/api-login/redirect-uri/index.html
FYERS_ACCESS_TOKEN=                      # filled in automatically by fyers_login.py

# --- Headless TOTP login (src/fyers_login.py / GitHub Action) ---
# Enable "External 2FA TOTP" at https://myaccount.fyers.in/ManageAccount first.
FYERS_FY_ID=your_fyers_id               # e.g. XN13999
FYERS_PIN=your_login_pin
FYERS_TOTP_SECRET=your_base32_totp_key
